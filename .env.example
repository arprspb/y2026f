DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/voice_commands
SECRET_KEY=замените-на-длинную-случайную-строку
VOSK_MODEL_PATH=./models/vosk-model-small-ru-0.22
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# Первый администратор: создаётся при старте API, если пользователя с таким логином ещё нет.
# Саморегистрация отключена — остальных пользователей создаёт админ в интерфейсе «Пользователи».
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=смените-пароль
